#include<stdio.h>
#include<ctype.h>
#include<string.h>
char p[10][10]; int n;
void first(char c){
    int i;
    if(!isupper(c)){ printf("%c ",c); return; }
    for(i=0;i<n;i++){
        if(p[i][0]==c){
            if(!isupper(p[i][2])) printf("%c ",p[i][2]);
            else first(p[i][2]);
        }
    }
}
int main(){
    int i; char c;
    scanf("%d",&n);
    for(i=0;i<n;i++) scanf("%s",p[i]);
    scanf(" %c",&c);
    first(c);
}
